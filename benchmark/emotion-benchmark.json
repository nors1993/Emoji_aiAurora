    { "name": "wink", "description": "眨眼" }
  ],

  "effects": [
    {
      "name": "shake",
      "description": "愤怒摇晃动画",
      "emotions": ["angry"],
      "axis": "x",
      "frequency_hz": 8,
      "amplitude": 0.05
    },
    {
      "name": "pulse",
      "description": "缩放脉冲动画",
      "emotions": ["excited", "love", "angry", "proud", "playful"],
      "scale_range": [0.98, 1.02],
      "frequency_hz": 2
    }
  ],

  "emotion_detection_chain": {
    "description": "优先级检测链",
    "priority_order": [
      {
        "step": 1,
        "name": "JSON Extraction",
        "description": "从LLM响应中提取JSON情绪",
        "patterns": ["{\"emotion\": \"...\"}", "emotion: \"...\""]
      },
      {
        "step": 2,
        "name": "Context Analysis",
        "description": "基于用户消息和回复上下文分析",
        "consider_user_message": true,
        "consider_personality": true
      },
      {
        "step": 3,
        "name": "Keyword Detection",
        "description": "关键词匹配",
        "case_insensitive": true
      },
      {
        "step": 4,
        "name": "Punctuation Analysis",
        "description": "标点符号分析",
        "rules": [
          { "pattern": "!!+", "emotion": "excited" },
          { "pattern": "\\?\\?+", "emotion": "confused" },
          { "pattern": "\\.\\.\\.|……", "emotion": "thinking" }
        ]
      },
      {
        "step": 5,
        "name": "Fallback",
        "description": "默认中性",
        "result": "neutral"
      }
    ]
  }
}